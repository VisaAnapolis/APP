<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>Checklists - Vigilância Sanitária</title>
  <meta name="theme-color" content="#1a3a6b">

  <!-- Sistema de Design - VISA Anápolis -->
  <link rel="stylesheet" href="./css/design-tokens.css">
  <link rel="stylesheet" href="./css/header-component.css">
  <link rel="stylesheet" href="./css/regulados.css">
  <link rel="stylesheet" href="./css/base.css">
  <link rel="stylesheet" href="./css/components.css">
  <link rel="stylesheet" href="./css/layouts.css">

  <style>
    /* Header agora usa header-component.css */

    /* ========================================
       HEADER PADRONIZADO - VISA Anápolis
       ======================================== */
    header.main-header.main-header.main-/* ========================================
       CONTAINER
       ======================================== */
    .container {
      max-width: 900px;
      margin: 22px auto 30px;
      padding: 0 16px;
      padding-bottom: calc(24px + env(safe-area-inset-bottom, 0px));
    }

    /* ========================================
       CARDS
       ======================================== */
    .card {
      background: var(--card, #ffffff);
      border-radius: 16px;
      padding: 20px 24px;
      margin-bottom: 16px;
      border: 1px solid var(--line, #e2e8f0);
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }

    .card__title {
      color: var(--brand1, #1a3a6b);
      font-size: 1.1em;
      font-weight: 700;
      margin-bottom: 16px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--brand1, #1a3a6b);
    }

    /* ========================================
       LISTA DE CHECKLISTS
       ======================================== */
    .checklist-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .checklist-list li {
      margin: 0;
      border-bottom: 1px solid var(--line, #e2e8f0);
    }

    .checklist-list li:last-child {
      border-bottom: none;
    }

    .checklist-list a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 12px;
      text-decoration: none;
      color: var(--text, #1a202c);
      font-weight: 600;
      transition: background 0.2s;
      border-radius: 8px;
      cursor: pointer;
    }

    .checklist-list a:hover {
      background: rgba(26, 58, 107, 0.05);
    }

    .checklist-list a::before {
      content: "📋";
      font-size: 1.2em;
    }

    .checklist-list a::after {
      content: "›";
      margin-left: auto;
      font-size: 1.4em;
      color: var(--muted, #64748b);
      font-weight: 300;
    }

    /* ========================================
       OBSERVAÇÃO
       ======================================== */
    .obs-text {
      font-size: 0.9em;
      color: var(--muted, #64748b);
      line-height: 1.5;
      padding: 16px;
      background: rgba(26, 58, 107, 0.04);
      border-radius: 8px;
      border-left: 4px solid var(--brand1, #1a3a6b);
    }

    .update-info {
      font-size: 0.85em;
      color: var(--muted, #64748b);
      margin-bottom: 16px;
    }

    /* ========================================
       MODAL DE PDF
       ======================================== */
    .pdf-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: var(--surface);
      z-index: var(--z-modal, 1050);
      /* Grid layout para garantir altura fixa do header/footer */
      display: none;
      grid-template-rows: auto 1fr auto;
    }

    .pdf-modal.active {
      display: grid;
    }

    .pdf-modal-.pdf-modal-title {
      font-size: 17px;
      font-weight: 600;
      margin: 0;
      flex: 1;
      text-align: center;
      padding: 0 40px;
    }

    .btn-fechar-pdf {
      position: absolute;
      left: 16px;
      background: transparent;
      border: none;
      color: #34C759;
      font-size: 17px;
      font-weight: 600;
      padding: 8px;
      cursor: pointer;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      z-index: 10001;
      min-width: 60px;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-fechar-pdf:hover {
      opacity: 0.7;
    }

    .btn-fechar-pdf:active {
      opacity: 0.5;
      transform: scale(0.95);
    }

    /* Garante que o botão sempre responda ao toque */
    .pdf-modal-header * {
      pointer-events: auto;
    }

    .pdf-iframe {
      /* Grid já controla a altura - não precisa de flex */
      border: none;
      width: 100%;
      height: 100%;
      background: var(--bg-secondary);
      /* Previne que o iframe expanda além do container */
      max-height: 100%;
      overflow: hidden;
      position: relative;
    }
    
    /* Container wrapper para o iframe */
    .pdf-container {
      width: 100%;
      height: 100%;
      overflow: hidden;
      position: relative;
      background: var(--bg-secondary);
      /* Altura máxima explícita */
      max-height: calc(100vh - 120px);
    }

    /* Força o iframe a não escapar do grid no Android */
    .pdf-modal.active .pdf-iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100% !important;
      height: 100% !important;
      max-width: 100vw;
      max-height: 100%;
    }
    
    /* Fallback para navegadores que não suportam object PDF */
    .pdf-iframe p {
      padding: 20px;
      text-align: center;
      color: var(--text, #1a202c);
    }
    
    .pdf-iframe a {
      color: var(--brand1, #1a3a6b);
      font-weight: 600;
    }

    .pdf-modal-footer {
      padding: 12px 16px;
      padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
      background: var(--surface-variant);
      border-top: 1px solid #e2e8f0;
      display: flex;
      justify-content: center;
      gap: 12px;
      /* Removido position sticky - grid já controla o layout */
      z-index: 10000;
      position: relative;
    }

    .btn-action-pdf {
      background: var(--primary);
      color: var(--text-primary);
      border: none;
      padding: 12px 24px;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      transition: background 0.2s;
      min-height: 44px;
      touch-action: manipulation;
    }

    .btn-action-pdf:hover {
      background: var(--primary-dark);
    }

    .btn-action-pdf:active {
      background: var(--primary-dark);
    }

    /* ========================================
       RESPONSIVO
       ======================================== */
    @media (max-width: 768px) {
      header.main-header {
        padding: 28px 70px 26px 20px;
      }

      .container {
        padding: 0 12px;
        margin: 16px auto 24px;
      }

      .card {
        padding: 16px;
        border-radius: 14px;
      }

      .checklist-list a {
        padding: 14px 10px;
        font-size: 0.95em;
      }

      .pdf-modal-title {
        font-size: 15px;
        padding: 0 20px;
      }

      .btn-action-pdf {
        padding: 10px 20px;
        font-size: 14px;
      }
    }
  </style>
</head>

<body>
  <!-- ========================================
       HEADER PADRONIZADO
       ======================================== -->
  <header class="app-header">
    <a href="index.html" class="btn-done-ios">OK</a>
    <h1 class="app-header__title">Vigilância Sanitária</h1>
    <h2 class="app-header__subtitle">Checklists de Inspeção</h2>
  </header>

  <!-- ========================================
       CONTEÚDO PRINCIPAL
       ======================================== -->
  <div class="container">
    
    <section class="card">
      <div class="card__title">📋 Checklists Disponíveis</div>
      
      <p class="update-info">
        🕐 Atualizado em 12/12/2025 12:14 (Horário de Brasília – UTC−3)
      </p>

      <ul class="checklist-list">
        <li>
          <a href="#" onclick="abrirPDF('check-list-saude-cnaes-baixas/original.pdf', 'Checklist SAÚDE – CNAEs baixas'); return false;">
            Checklist SAÚDE – CNAEs baixas
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-varejista-cosme-e-san/original.pdf', 'Checklist Varejista – Cosméticos e Saneantes'); return false;">
            Checklist Varejista – Cosméticos e Saneantes
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-acougue/original.pdf', 'Checklist – Açougue'); return false;">
            Checklist – Açougue
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-alimentos-geral/original.pdf', 'Checklist – Alimentos (Geral)'); return false;">
            Checklist – Alimentos (Geral)
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-drogarias-1/original.pdf', 'Checklist – Drogarias'); return false;">
            Checklist – Drogarias
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-saude-cnaes-8630502-e-8630503/original.pdf', 'Checklist Saúde – CNAEs 8630502 / 8630503'); return false;">
            Checklist Saúde – CNAEs 8630502 / 8630503
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-atacadista-cosme-e-saneantes/original.pdf', 'Checklist Atacadista – Cosméticos e Saneantes'); return false;">
            Checklist Atacadista – Cosméticos e Saneantes
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('check-list-escola/original.pdf', 'Checklist – Escola'); return false;">
            Checklist – Escola
          </a>
        </li>
        <li>
          <a href="#" onclick="abrirPDF('checklist-academia/original.pdf', 'Checklist – Academia'); return false;">
            Checklist – Academia
          </a>
        </li>
      </ul>
    </section>

    <p class="obs-text">
      <strong>Observação:</strong> estes HTMLs exibem as páginas como imagens para preservar a
      fidelidade do formulário original. A versão preenchível será implantada
      em etapa posterior.
    </p>

  </div>

  <!-- ========================================
       MODAL DE VISUALIZAÇÃO DE PDF
       ======================================== -->
  <div id="pdfModal" class="pdf-modal">
    <div class="pdf-modal-header">
      <button onclick="fecharPDF()" class="btn-fechar-pdf">Fechar</button>
      <h3 id="pdfTitle" class="pdf-modal-title">Visualizando PDF</h3>
    </div>
    <div class="pdf-container">
      <object id="pdfViewer" class="pdf-iframe" type="application/pdf">
        <p>Seu navegador não suporta visualização de PDF. <a id="pdfDownloadLink" href="">Clique aqui para baixar</a></p>
      </object>
    </div>
    <div class="pdf-modal-footer">
      <button onclick="abrirEmNovaAba()" class="btn-action-pdf">
        📂 Abrir Externamente
      </button>
      <button onclick="baixarPDF()" class="btn-action-pdf">
        ⬇️ Baixar PDF
      </button>
    </div>
  </div>

  <!-- ========================================
       SCRIPTS
       ======================================== -->
  <script>
    let pdfAtual = '';

    function abrirPDF(url, titulo) {
      pdfAtual = url;
      document.getElementById('pdfTitle').textContent = titulo;
      
      // Usando object em vez de iframe.src
      const pdfViewer = document.getElementById('pdfViewer');
      pdfViewer.setAttribute('data', url);
      
      // Atualiza link de download fallback
      const downloadLink = document.getElementById('pdfDownloadLink');
      if (downloadLink) {
        downloadLink.href = url;
      }
      
      document.getElementById('pdfModal').classList.add('active');
      
      // Previne scroll do body quando modal está aberto
      document.body.style.overflow = 'hidden';
      
      // Oculta header principal para evitar sobreposição
      const header = document.querySelector('.app-header');
      if (header) header.style.display = 'none';
    }

    function fecharPDF() {
      document.getElementById('pdfModal').classList.remove('active');
      
      // Limpa o object
      const pdfViewer = document.getElementById('pdfViewer');
      pdfViewer.setAttribute('data', '');
      
      pdfAtual = '';
      
      // Restaura scroll do body
      document.body.style.overflow = '';
      
      // Mostra header novamente
      const header = document.querySelector('.app-header');
      if (header) header.style.display = '';
    }

    function abrirEmNovaAba() {
      if (pdfAtual) {
        window.open(pdfAtual, '_blank', 'noopener,noreferrer');
      }
    }

    function baixarPDF() {
      if (pdfAtual) {
        const link = document.createElement('a');
        link.href = pdfAtual;
        link.download = pdfAtual.split('/').pop();
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      }
    }

    // Fechar modal ao pressionar ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && document.getElementById('pdfModal').classList.contains('active')) {
        fecharPDF();
      }
    });
  </script>

  <!-- Platform Detector -->
  <script src="./js/platform-detector.js"></script>
</body>
</html>
