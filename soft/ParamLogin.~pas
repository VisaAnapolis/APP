unit ParamLogin;

interface

uses
  Windows, Messages, SysUtils, Classes, Graphics, Controls, Forms, Dialogs,
  DB, DBTables, Grids, DBGrids, StdCtrls, ExtCtrls, DBCtrls, ResetSenha;

type
  TfrmParamLogin = class(TForm)
    PanelTop: TPanel;
    BtnNovo: TButton;
    BtnAlterar: TButton;
    BtnExcluir: TButton;
    BtnSalvar: TButton;
    BtnCancelar: TButton;
    BtnFechar: TButton;
    BtnResetarSenha: TButton;
    BtnDesativar: TButton;
    BtnAtivar: TButton;
    PanelEdicao: TPanel;
    Grid: TDBGrid;
    Ds: TDataSource;
    Tb: TTable;
    procedure FormActivate(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure BtnFecharClick(Sender: TObject);
    procedure BtnNovoClick(Sender: TObject);
    procedure BtnAlterarClick(Sender: TObject);
    procedure BtnExcluirClick(Sender: TObject);
    procedure BtnSalvarClick(Sender: TObject);
    procedure BtnCancelarClick(Sender: TObject);
    procedure BtnResetarSenhaClick(Sender: TObject);
    procedure BtnDesativarClick(Sender: TObject);
    procedure BtnAtivarClick(Sender: TObject);
    procedure DsStateChange(Sender: TObject);
    procedure DsDataChange(Sender: TObject; Field: TField);
  private
    FFirstEdit: TWinControl;
    FClosing: Boolean;
    procedure AtualizaBotoes;
    procedure ApplyFieldRules;
    procedure EnterEditMode;
    procedure ExitEditMode;
    procedure ClearEditors;
    procedure BuildEditors;
    procedure EditEnterAsTab(Sender: TObject; var Key: Char);
  public
  end;

var
  frmParamLogin: TfrmParamLogin;

implementation

uses login;

{$R *.dfm}

procedure TfrmParamLogin.EditEnterAsTab(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
  begin
    Key := #0;
    Perform(WM_NEXTDLGCTL, 0, 0);
  end;
end;

procedure TfrmParamLogin.ClearEditors;
var
  i: Integer;
begin
  FFirstEdit := nil;
  for i := PanelEdicao.ControlCount - 1 downto 0 do
    PanelEdicao.Controls[i].Free;
end;

procedure TfrmParamLogin.BuildEditors;
var
  i, Col, Row: Integer;
  F: TField;
  L: TLabel;
  E: TDBEdit;
  C: TDBComboBox;
  LeftBase, TopBase, ColW, RowH, GapX, GapY, MaxCols: Integer;
begin
  if not Tb.Active then Exit;

  ClearEditors;

  LeftBase := 12;
  TopBase := 10;
  ColW := 270;
  RowH := 44;
  GapX := 12;
  GapY := 6;
  MaxCols := 3;

  Col := 0;
  Row := 0;

  for i := 0 to Tb.FieldCount - 1 do
  begin
    F := Tb.Fields[i];

    if (not F.Visible) then Continue;
    if F.FieldKind <> fkData then Continue;

    L := TLabel.Create(PanelEdicao);
    L.Parent := PanelEdicao;
    L.Caption := F.DisplayName;
    L.Left := LeftBase + Col * (ColW + GapX);
    L.Top := TopBase + Row * (RowH + GapY);

    if F.FieldName = 'GRUPO' then
    begin
      C := TDBComboBox.Create(PanelEdicao);
      C.Parent := PanelEdicao;
      C.Left := L.Left;
      C.Top := L.Top + 16;
      C.Width := ColW;
      C.Height := 21;
      C.DataSource := Ds;
      C.DataField := F.FieldName;
      C.Style := csDropDownList;
      C.Items.Add('ADM');
      C.Items.Add('FIS');
      C.Items.Add('CAD');
      C.Items.Add('CON');
      C.Items.Add('DES');
      C.TabOrder := (Row * MaxCols + Col);
      if FFirstEdit = nil then FFirstEdit := C;
    end
    else
    begin
      E := TDBEdit.Create(PanelEdicao);
      E.Parent := PanelEdicao;
      E.Left := L.Left;
      E.Top := L.Top + 16;
      E.Width := ColW;
      E.Height := 21;
      E.DataSource := Ds;
      E.DataField := F.FieldName;
      E.TabOrder := (Row * MaxCols + Col);
      E.OnKeyPress := EditEnterAsTab;
      if FFirstEdit = nil then FFirstEdit := E;
    end;

    Inc(Col);
    if Col >= MaxCols then
    begin
      Col := 0;
      Inc(Row);
    end;
  end;
end;

procedure TfrmParamLogin.ApplyFieldRules;
var
  i: Integer;
  HideName: string;
const
  HiddenFields: array[0..3] of string = ('CONTROLE', 'SENHA', 'SENHA2', 'SENHA3');
begin
  for i := Low(HiddenFields) to High(HiddenFields) do
  begin
    HideName := HiddenFields[i];
    if Tb.FindField(HideName) <> nil then
    begin
      Tb.FieldByName(HideName).Visible := False;
      Tb.FieldByName(HideName).ReadOnly := True;
    end;
  end;

  if Tb.FindField('DATA') <> nil then
    Tb.FieldByName('DATA').ReadOnly := True;

  Ds.AutoEdit := False;
  Grid.ReadOnly := True;
end;

procedure TfrmParamLogin.EnterEditMode;
begin
  PanelEdicao.Enabled := True;
  Grid.Enabled := False;
  Grid.ReadOnly := True;

  if (FFirstEdit <> nil) and FFirstEdit.CanFocus then
    FFirstEdit.SetFocus;
end;

procedure TfrmParamLogin.ExitEditMode;
begin
  PanelEdicao.Enabled := False;
  Grid.Enabled := True;
  Grid.ReadOnly := True;
end;

procedure TfrmParamLogin.FormActivate(Sender: TObject);
begin
  FClosing := False; // importante: garante que n緌 fica "travado" ao reabrir

  Session.AddPassword('paradiso');

  if not Tb.Active then
    Tb.Open;

  ApplyFieldRules;
  BuildEditors;

  ExitEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamLogin.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  // Se estiver editando, cancela
  if Tb.Active and (Tb.State in [dsEdit, dsInsert]) then
    Tb.Cancel;

  // N鬃 desmonta DataSource / Grid / DBEdits aqui
  // N鬃 fecha Tb aqui

  Action := caHide;
end;

procedure TfrmParamLogin.BtnFecharClick(Sender: TObject);
begin
  if Tb.Active and (Tb.State in [dsEdit, dsInsert]) then
    Tb.Cancel;
  Close;
end;

procedure TfrmParamLogin.BtnNovoClick(Sender: TObject);
begin
  Tb.Append;
  EnterEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamLogin.BtnAlterarClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;

  Tb.Edit;
  EnterEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamLogin.BtnExcluirClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;

  if MessageDlg('Confirma excluir este registro?', mtConfirmation, [mbYes, mbNo], 0) = mrYes then
    Tb.Delete;

  AtualizaBotoes;
end;

procedure TfrmParamLogin.BtnSalvarClick(Sender: TObject);
var
  FoiInsercao: Boolean;
  NomeUsuario: string;
  Grp: string;
  frm: TfrmResetSenha;
begin
  FoiInsercao := (Tb.State = dsInsert);
  if FoiInsercao then
    NomeUsuario := Tb.FieldByName('USUARIO').AsString;

  if Tb.State in [dsInsert, dsEdit] then
  begin
    Grp := Tb.FieldByName('GRUPO').AsString;
    if (Grp <> 'ADM') and (Grp <> 'FIS') and (Grp <> 'CAD') and
       (Grp <> 'CON') and (Grp <> 'DES') then
    begin
      ShowMessage('Grupo inv' + Chr(225) + 'lido. Selecione: ADM, FIS, CAD ou CON.');
      Exit;
    end;
    Tb.Post;
  end;

  ExitEditMode;
  AtualizaBotoes;

  // Para novo usu嫫io sem senha, exigir defini誽o imediata
  if FoiInsercao and Tb.Active and (Tb.FieldByName('SENHA').AsString = '') then
  begin
    frm := TfrmResetSenha.Create(Self);
    try
      frm.NomeUsuario := NomeUsuario;
      if frm.ShowModal <> mrOk then
      begin
        ShowMessage('Opera誽o cancelada. O usu嫫io foi removido pois a senha n緌 foi definida.');
        Tb.Delete;
      end;
    finally
      frm.Free;
    end;
    AtualizaBotoes;
  end;

  if Grid.CanFocus then Grid.SetFocus;
end;

procedure TfrmParamLogin.BtnResetarSenhaClick(Sender: TObject);
var
  frm: TfrmResetSenha;
begin
  if Tb.IsEmpty then Exit;

  frm := TfrmResetSenha.Create(Self);
  try
    frm.NomeUsuario := Tb.FieldByName('USUARIO').AsString;
    frm.ShowModal;
  finally
    frm.Free;
  end;
end;

procedure TfrmParamLogin.BtnCancelarClick(Sender: TObject);
begin
  if Tb.State in [dsInsert, dsEdit] then
    Tb.Cancel;

  ExitEditMode;
  AtualizaBotoes;

  if Grid.CanFocus then Grid.SetFocus;
end;

procedure TfrmParamLogin.DsStateChange(Sender: TObject);
begin
  if FClosing then Exit;       // <-- ESSENCIAL (era o que estava faltando)
  AtualizaBotoes;
end;

procedure TfrmParamLogin.DsDataChange(Sender: TObject; Field: TField);
begin
  if FClosing then Exit;
  AtualizaBotoes;
end;

procedure TfrmParamLogin.AtualizaBotoes;
var
  EmEdicao: Boolean;
  GrupoAtual: string;
begin
  if FClosing or (not Tb.Active) then
  begin
    BtnNovo.Enabled         := False;
    BtnAlterar.Enabled      := False;
    BtnExcluir.Enabled      := False;
    BtnSalvar.Enabled       := False;
    BtnCancelar.Enabled     := False;
    BtnResetarSenha.Enabled := False;
    BtnDesativar.Enabled    := False;
    BtnAtivar.Enabled       := False;
    Exit;
  end;

  EmEdicao := (Tb.State in [dsInsert, dsEdit]);

  GrupoAtual := '';
  if (not EmEdicao) and (not Tb.IsEmpty) then
    GrupoAtual := Tb.FieldByName('GRUPO').AsString;

  BtnNovo.Enabled         := not EmEdicao;
  BtnAlterar.Enabled      := (not EmEdicao) and (not Tb.IsEmpty);
  BtnExcluir.Enabled      := (not EmEdicao) and (not Tb.IsEmpty) and (frmlogin.c_user = 'CL糢DIO NASCIMENTO SILVA');
  BtnResetarSenha.Enabled := (not EmEdicao) and (not Tb.IsEmpty);
  BtnDesativar.Enabled    := (not EmEdicao) and (not Tb.IsEmpty) and (GrupoAtual <> 'DES');
  BtnAtivar.Enabled       := (not EmEdicao) and (not Tb.IsEmpty) and (GrupoAtual = 'DES');

  BtnSalvar.Enabled   := EmEdicao;
  BtnCancelar.Enabled := EmEdicao;
end;

procedure TfrmParamLogin.BtnDesativarClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;
  if MessageDlg('Desativar o usu' + Chr(225) + 'rio "' + Tb.FieldByName('USUARIO').AsString + '"?',
     mtConfirmation, [mbYes, mbNo], 0) = mrYes then
  begin
    Tb.Edit;
    Tb.FieldByName('GRUPO').AsString := 'DES';
    Tb.Post;
    AtualizaBotoes;
  end;
end;

procedure TfrmParamLogin.BtnAtivarClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;
  if MessageDlg('Ativar o usu嫫io "' + Tb.FieldByName('USUARIO').AsString + '" com grupo CON?',
     mtConfirmation, [mbYes, mbNo], 0) = mrYes then
  begin
    Tb.Edit;
    Tb.FieldByName('GRUPO').AsString := 'CON';
    Tb.Post;
    AtualizaBotoes;
    ShowMessage(
      'Usu嫫io reativado com grupo CON (Consulta).' + #13#10 +
      'Lembre-se de ajustar o grupo conforme a fun誽o do usu嫫io:' + #13#10 +
      '  ADM  - Administrador' + #13#10 +
      '  FIS  - Fiscal' + #13#10 +
      '  CAD  - Administrativo' + #13#10 +
      '  CON  - Consulta (somente leitura)');
  end;
end;

end.

