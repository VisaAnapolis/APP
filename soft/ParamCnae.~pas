unit ParamCnae;

interface

uses
  Windows, Messages, SysUtils, Classes, Graphics, Controls, Forms, Dialogs,
  DB, DBTables, Grids, DBGrids, StdCtrls, ExtCtrls, DBCtrls;

type
  TfrmParamCnae = class(TForm)
    PanelTop: TPanel;
    BtnNovo: TButton;
    BtnAlterar: TButton;
    BtnExcluir: TButton;
    BtnSalvar: TButton;
    BtnCancelar: TButton;
    BtnFechar: TButton;
    PanelEdicao: TPanel;
    Grid: TDBGrid;
    Ds: TDataSource;
    Tb: TTable;
    procedure FormActivate(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure BtnFecharClick(Sender: TObject);
    procedure BtnNovoClick(Sender: TObject);
    procedure BtnAlterarClick(Sender: TObject);
    procedure BtnExcluirClick(Sender: TObject);
    procedure BtnSalvarClick(Sender: TObject);
    procedure BtnCancelarClick(Sender: TObject);
    procedure DsStateChange(Sender: TObject);
  private
    FFirstEdit: TWinControl;
    procedure AtualizaBotoes;
    procedure ApplyFieldRules;
    procedure EnterEditMode;
    procedure ExitEditMode;
    procedure ClearEditors;
    procedure BuildEditors;
    procedure AjustaColunasGrid;
    procedure EditEnterAsTab(Sender: TObject; var Key: Char);

    function NormalizaMaiusculo(const S: string): string;
    function IsEquipeValida(const S: string): Boolean;
    function IsComplexidadeValida(const S: string): Boolean;
    procedure ValidaAntesDeSalvar;


  public
  end;

var
  frmParamCnae: TfrmParamCnae;

implementation

{$R *.dfm}


function TfrmParamCnae.NormalizaMaiusculo(const S: string): string;
begin
  Result := Trim(AnsiUpperCase(S));
end;

function TfrmParamCnae.IsEquipeValida(const S: string): Boolean;
var
  X: string;
begin
  X := NormalizaMaiusculo(S);
  Result :=
    (X = '') or  // permite vazio se quiser (se nŃo quiser, eu retiro)
    (X = 'IA') or (X = 'AG') or (X = 'ED') or (X = 'OS') or
    (X = 'SS') or (X = 'OD') or (X = 'CS') or (X = 'AM') or
    (X = 'VT') or (X = 'BI') or (X = 'LP') or (X = 'AO') or
    (X = 'TR') or (X = 'FU') or (X = 'DR') or (X = 'MD');
end;

function TfrmParamCnae.IsComplexidadeValida(const S: string): Boolean;
var
  X: string;
begin
  X := NormalizaMaiusculo(S);
  Result :=
    (X = '') or  // permite vazio se quiser (se nŃo quiser, eu retiro)
    (X = 'ALTA') or (X = 'M╔DIA') or (X = 'BAIXA');
end;

procedure TfrmParamCnae.ValidaAntesDeSalvar;
var
  Eq, Cx: string;
begin
  if Tb.FindField('EQUIPE') <> nil then
  begin
    Eq := NormalizaMaiusculo(Tb.FieldByName('EQUIPE').AsString);
    Tb.FieldByName('EQUIPE').AsString := Eq;

    if not IsEquipeValida(Eq) then
    begin
      MessageDlg('Equipe invßlida. Use apenas: IA, AG, ED, OS, SS, OD, CS, AM, VT, BI, LP, AO, TR, FU, DR, MD.', mtWarning, [mbOK], 0);
      Abort;
    end;
  end;

  if Tb.FindField('COMPLEXIDADE') <> nil then
  begin
    Cx := NormalizaMaiusculo(Tb.FieldByName('COMPLEXIDADE').AsString);
    Tb.FieldByName('COMPLEXIDADE').AsString := Cx;

    if not IsComplexidadeValida(Cx) then
    begin
      MessageDlg('Complexidade invßlida. Use apenas: ALTA, M╔DIA, BAIXA.', mtWarning, [mbOK], 0);
      Abort;
    end;
  end;
end;



procedure TfrmParamCnae.EditEnterAsTab(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
  begin
    Key := #0;
    Perform(WM_NEXTDLGCTL, 0, 0);
  end;
end;

procedure TfrmParamCnae.ClearEditors;
var
  i: Integer;
begin
  FFirstEdit := nil;
  for i := PanelEdicao.ControlCount - 1 downto 0 do
    PanelEdicao.Controls[i].Free;
end;

procedure TfrmParamCnae.BuildEditors;
var
  i, Col, Row: Integer;
  F: TField;
  L: TLabel;
  E: TDBEdit;
  LeftBase, TopBase, ColW, RowH, GapX, GapY, MaxCols: Integer;
begin
  if not Tb.Active then Exit;

  ClearEditors;

  LeftBase := 12;
  TopBase := 10;
  ColW := 270;
  RowH := 44;
  GapX := 12;
  GapY := 6;
  MaxCols := 3;

  Col := 0;
  Row := 0;

  for i := 0 to Tb.FieldCount - 1 do
  begin
    F := Tb.Fields[i];

    if (not F.Visible) then Continue;
    if F.FieldKind <> fkData then Continue;

    L := TLabel.Create(PanelEdicao);
    L.Parent := PanelEdicao;
    L.Caption := F.DisplayName;
    L.Left := LeftBase + Col * (ColW + GapX);
    L.Top := TopBase + Row * (RowH + GapY);

    E := TDBEdit.Create(PanelEdicao);
    E.Parent := PanelEdicao;
    E.Left := L.Left;
    E.Top := L.Top + 16;
    E.Width := ColW;
    E.Height := 21;
    E.DataSource := Ds;
    E.DataField := F.FieldName;
    E.TabOrder := (Row * MaxCols + Col);
    E.OnKeyPress := EditEnterAsTab;

    if FFirstEdit = nil then
      FFirstEdit := E;

    Inc(Col);
    if Col >= MaxCols then
    begin
      Col := 0;
      Inc(Row);
    end;
  end;
end;

procedure TfrmParamCnae.ApplyFieldRules;
var
  i: Integer;
  HideName: string;
const
  HiddenFields: array[0..1] of string = ('CONTROLE', 'CLASSE');
begin
  for i := Low(HiddenFields) to High(HiddenFields) do
  begin
    HideName := HiddenFields[i];
    if Tb.FindField(HideName) <> nil then
    begin
      Tb.FieldByName(HideName).Visible := False;
      Tb.FieldByName(HideName).ReadOnly := True;
    end;
  end;

  Ds.AutoEdit := False;

  Grid.ReadOnly := True;
end;

procedure TfrmParamCnae.EnterEditMode;
begin
  PanelEdicao.Enabled := True;
  Grid.Enabled := False;
  Grid.ReadOnly := True;

  if (FFirstEdit <> nil) and FFirstEdit.CanFocus then
    FFirstEdit.SetFocus;
end;

procedure TfrmParamCnae.ExitEditMode;
begin
  PanelEdicao.Enabled := False;
  Grid.Enabled := True;
  Grid.ReadOnly := True;
end;

procedure TfrmParamCnae.FormActivate(Sender: TObject);
begin
  Session.AddPassword('paradiso');

  if not Tb.Active then
  begin
    Tb.Open;
  end;

  ApplyFieldRules;
  BuildEditors;
  AjustaColunasGrid;
  ExitEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamCnae.AjustaColunasGrid;
var
  i: Integer;
begin
  // S¾ funciona se vocĻ tiver Columns persistentes no grid
  for i := 0 to Grid.Columns.Count - 1 do
    if SameText(Grid.Columns[i].FieldName, 'ATIVIDADE') then
    begin
      Grid.Columns[i].Width := 600;  // ajuste aqui
      Break;
    end;
end;


procedure TfrmParamCnae.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  if Tb.Active then
    Tb.Close;

  Action := caFree;
end;

procedure TfrmParamCnae.BtnFecharClick(Sender: TObject);
begin
  Close;
end;


procedure TfrmParamCnae.BtnNovoClick(Sender: TObject);
begin
  Tb.Append;
  EnterEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamCnae.BtnAlterarClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;

  Tb.Edit;
  EnterEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamCnae.BtnExcluirClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;

  if MessageDlg('Confirma excluir este registro?', mtConfirmation, [mbYes, mbNo], 0) = mrYes then
    Tb.Delete;

  AtualizaBotoes;
end;

procedure TfrmParamCnae.BtnSalvarClick(Sender: TObject);
begin
  if Tb.State in [dsInsert, dsEdit] then
  begin
    ValidaAntesDeSalvar;
    Tb.Post;
  end;
  ExitEditMode;
  AtualizaBotoes;

  if Grid.CanFocus then Grid.SetFocus;
end;

procedure TfrmParamCnae.BtnCancelarClick(Sender: TObject);
begin
  if Tb.State in [dsInsert, dsEdit] then
    Tb.Cancel;

  ExitEditMode;
  AtualizaBotoes;

  if Grid.CanFocus then Grid.SetFocus;
end;

procedure TfrmParamCnae.DsStateChange(Sender: TObject);
begin
  AtualizaBotoes;
end;

procedure TfrmParamCnae.AtualizaBotoes;
var
  EmEdicao: Boolean;
begin
  EmEdicao := (Tb.State in [dsInsert, dsEdit]);

  BtnNovo.Enabled     := not EmEdicao;
  BtnAlterar.Enabled  := (not EmEdicao) and (not Tb.IsEmpty);
  BtnExcluir.Enabled  := (not EmEdicao) and (not Tb.IsEmpty);

  BtnSalvar.Enabled   := EmEdicao;
  BtnCancelar.Enabled := EmEdicao;
end;

end.
