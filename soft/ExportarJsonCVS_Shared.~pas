unit ExportarJsonCVS_Shared;

interface

uses
  Windows, SysUtils, Classes, DB, DBTables;

function ExportarJsonCVS_Shared(const AliasOrPath, OutBaseDir: string; out Erro: string): Boolean;

implementation

type
  TBytes = array of Byte;

function EnsureSlash(const S: string): string;
begin
  Result := S;
  if (Result <> '') and (Result[Length(Result)] <> '\') then
    Result := Result + '\';
end;

function NowISO_Brasilia: string;
begin
  Result := FormatDateTime('yyyy"-"mm"-"dd"T"hh":"nn":"ss', Now) + '-03:00';
end;

function DateISO(const D: TDateTime): string;
begin
  Result := FormatDateTime('yyyy"-"mm"-"dd', D);
end;

// -------- UTF-8 (Delphi 6) --------
function Utf8BytesFromWide(const WS: WideString): TBytes;
var
  Len: Integer;
begin
  SetLength(Result, 0);
  if WS = '' then Exit;
  Len := WideCharToMultiByte(CP_UTF8, 0, PWideChar(WS), Length(WS), nil, 0, nil, nil);
  if Len <= 0 then Exit;
  SetLength(Result, Len);
  WideCharToMultiByte(CP_UTF8, 0, PWideChar(WS), Length(WS), PAnsiChar(@Result[0]), Len, nil, nil);
end;

procedure SaveUtf8ToFile(const FileName: string; const Content: WideString);
var
  FS: TFileStream;
  B: TBytes;
begin
  ForceDirectories(ExtractFileDir(FileName));
  FS := TFileStream.Create(FileName, fmCreate);
  try
    B := Utf8BytesFromWide(Content);
    if Length(B) > 0 then
      FS.WriteBuffer(B[0], Length(B));
  finally
    FS.Free;
  end;
end;

// -------- JSON helpers --------
function JsonEscape(const S: string): WideString;
var
  i: Integer;
  ch: Char;
begin
  Result := '';
  for i := 1 to Length(S) do
  begin
    ch := S[i];
    case ch of
      '"':  Result := Result + '\"';
      '\':  Result := Result + '\\';
      #8:   Result := Result + '\b';
      #9:   Result := Result + '\t';
      #10:  Result := Result + '\n';
      #12:  Result := Result + '\f';
      #13:  Result := Result + '\r';
    else
      Result := Result + WideString(ch);
    end;
  end;
end;

function JStr(const S: string): WideString;
begin
  Result := '"' + JsonEscape(S) + '"';
end;

function JNull: WideString;
begin
  Result := 'null';
end;

function JBool(B: Boolean): WideString;
begin
  if B then Result := 'true' else Result := 'false';
end;

function IfThenW(const Cond: Boolean; const A, B: WideString): WideString;
begin
  if Cond then Result := A else Result := B;
end;

function NormalizeCodigo5(const CodigoInt: Integer): string;
begin
  Result := Format('%.5d', [CodigoInt]);
end;

function RegPrefix(const CodigoInt: Integer): string;
begin
  Result := Copy(NormalizeCodigo5(CodigoInt), 1, 2);  // 12345 -> '12'
end;

function HisBucket(const NDoc: Integer): string;
begin
  Result := Format('%.2d', [NDoc mod 100]); // 00..99
end;

// -------- load maps (bairros e cnae) --------
procedure LoadBairros(const AliasOrPath: string; MapCodigoToNome: TStringList);
var
  T: TTable;
  codigo, nome: string;
begin
  MapCodigoToNome.Clear;
  T := TTable.Create(nil);
  try
    T.DatabaseName := AliasOrPath;
    T.TableName := 'BAIRRO.DB';
    T.IndexName := 'PorCodigo';
    T.Open;
    try
      T.First;
      while not T.Eof do
      begin
        codigo := Trim(T.FieldByName('CODIGO').AsString);
        nome   := Trim(T.FieldByName('NOME').AsString);
        if (codigo <> '') and (MapCodigoToNome.IndexOfName(codigo) < 0) then
          MapCodigoToNome.Values[codigo] := nome;
        T.Next;
      end;
    finally
      T.Close;
    end;
  finally
    T.Free;
  end;
end;

procedure LoadCNAE(const AliasOrPath: string; MapSubToPacked: TStringList);
var
  T: TTable;
  sub, classe, ativ, equipe, comp: string;
begin
  MapSubToPacked.Clear;
  T := TTable.Create(nil);
  try
    T.DatabaseName := AliasOrPath;
    T.TableName := 'CNAE.DB';
    T.IndexName := 'PorSubclasse';
    T.Open;
    try
      T.First;
      while not T.Eof do
      begin
        sub    := Trim(T.FieldByName('SUBCLASSE').AsString);
        classe := Trim(T.FieldByName('CLASSE').AsString);
        ativ   := Trim(T.FieldByName('ATIVIDADE').AsString);
        equipe := Trim(T.FieldByName('EQUIPE').AsString);
        comp   := Trim(T.FieldByName('COMPLEXIDADE').AsString);

        if (sub <> '') and (MapSubToPacked.IndexOfName(sub) < 0) then
          MapSubToPacked.Values[sub] := sub + '|' + classe + '|' + ativ + '|' + equipe + '|' + comp;

        T.Next;
      end;
    finally
      T.Close;
    end;
  finally
    T.Free;
  end;
end;

// -------- último alvará válido (năo cancelado) --------
function UltimoAlvaraValidoJson(const AliasOrPath: string; const CodigoRegulado: Integer): WideString;
var
  T: TTable;
  best: TDateTime;
  has: Boolean;
  cancela: Boolean;
  dtEmite, dtVal, status: string;
  numero: Integer;
begin
  Result := JNull;
  has := False;
  best := 0;

  T := TTable.Create(nil);
  try
    T.DatabaseName := AliasOrPath;
    T.TableName := 'ALVARA.DB';
    // usando índice por código (e se vocę tiver por codigo+validade, melhor)
    // ajuste conforme seu índice real:
    // T.IndexName := 'PorCodigoValidade';
    T.IndexName := 'PorCodigo';

    T.Open;
    try
      T.SetRange([CodigoRegulado], [CodigoRegulado]);

      T.First;
      while not T.Eof do
      begin
        // filtro: ignora cancelado
        cancela := (not T.FieldByName('CANCELA').IsNull) and T.FieldByName('CANCELA').AsBoolean;
        if cancela then
        begin
          T.Next;
          Continue;
        end;

        if not T.FieldByName('DT_EMITE').IsNull then
        begin
          if (not has) or (T.FieldByName('DT_EMITE').AsDateTime > best) then
          begin
            has := True;
            best := T.FieldByName('DT_EMITE').AsDateTime;

            numero := T.FieldByName('NUMERO').AsInteger;
            status := Trim(T.FieldByName('STATUS').AsString);
            dtEmite := DateISO(T.FieldByName('DT_EMITE').AsDateTime);

            if T.FieldByName('DT_VALIDADE').IsNull then dtVal := '' else dtVal := DateISO(T.FieldByName('DT_VALIDADE').AsDateTime);

            Result :=
              '{' +
                '"numero":' + IntToStr(numero) + ',' +
                '"status":' + JStr(status) + ',' +
                '"dt_emite":' + JStr(dtEmite) + ',' +
                '"dt_validade":' + IfThenW(dtVal<>'', JStr(dtVal), JNull) +
              '}';
          end;
        end;

        T.Next;
      end;

      if not has then
        Result := JNull;

    finally
      T.Close;
    end;
  finally
    T.Free;
  end;
end;

// -------- inspeçőes do regulado (ordenadas desc por data) --------
// Para ordenar DESC sem varrer tudo, eu recomendo exportar como vier (índice por data)
// mas como vocę quer por regulado, usamos SetRange por CODIGO.
// Se quiser DESC, podemos coletar e ordenar em memória (média 5 = trivial).
procedure GetInspecoesJson(const AliasOrPath: string; const CodigoRegulado: Integer; out JsonArray: WideString);
type
  TIns = record
    dt: TDateTime;
    ndoc: Integer;
    controle: Integer;
  end;
var
  T: TTable;
  items: array of TIns;
  n: Integer;

  procedure AddItem(const AControle, ANDoc: Integer; const ADt: TDateTime);
  begin
    Inc(n);
    SetLength(items, n);
    items[n-1].controle := AControle;
    items[n-1].ndoc := ANDoc;
    items[n-1].dt := ADt;
  end;

  procedure SortDescByDate;
  var
    i, j: Integer;
    tmp: TIns;
  begin
    for i := 0 to n-2 do
      for j := i+1 to n-1 do
        if items[j].dt > items[i].dt then
        begin
          tmp := items[i];
          items[i] := items[j];
          items[j] := tmp;
        end;
  end;

var
  i: Integer;
  dtv: TDateTime;
begin
  JsonArray := '[]';
  n := 0;

  T := TTable.Create(nil);
  try
    T.DatabaseName := AliasOrPath;
    T.TableName := 'VISITAS.DB';
    T.IndexName := 'PorCodigo';

    T.Open;
    try
      T.SetRange([CodigoRegulado], [CodigoRegulado]);

      T.First;
      while not T.Eof do
      begin
        if T.FieldByName('DT_VISITA').IsNull then
          dtv := 0
        else
          dtv := T.FieldByName('DT_VISITA').AsDateTime;

        AddItem(
          T.FieldByName('CONTROLE').AsInteger,
          T.FieldByName('NDOC').AsInteger,
          dtv
        );

        T.Next;
      end;
    finally
      T.Close;
    end;
  finally
    T.Free;
  end;

  if n = 0 then Exit;

  SortDescByDate;

  JsonArray := '[';
  for i := 0 to n-1 do
  begin
    if i > 0 then JsonArray := JsonArray + ',';
    JsonArray := JsonArray +
      '{' +
        '"controle":' + IntToStr(items[i].controle) + ',' +
        '"ndoc":' + IntToStr(items[i].ndoc) + ',' +
        '"dt_visita":' + IfThenW(items[i].dt<>0, JStr(DateISO(items[i].dt)), JNull) +
      '}';
  end;
  JsonArray := JsonArray + ']';
end;

// -------- atividades do regulado (CAE múltiplas + descriçăo CNAE) --------
// Como CAE.CODIGO é A(5) e CONTRIB.CODIGO é I, usamos NormalizeCodigo5.
procedure GetAtividadesJson(const AliasOrPath: string; const CodigoRegulado: Integer; const MapCnae: TStringList; out JsonArray: WideString);
var
  T: TTable;
  cod5: string;
  sub, classe, tipo, caeCod: string;
  packed, rest: string;
  cnaeClasse, cnaeAtiv, cnaeEquipe, cnaeComp: string;
  first: Boolean;

  procedure ParseCnaePacked(const P: string);
  var
    s: string;
  begin
    cnaeClasse := ''; cnaeAtiv := ''; cnaeEquipe := ''; cnaeComp := '';
    s := P;
    if s = '' then Exit;

    // s: sub|classe|atividade|equipe|complexidade
    // remove sub|
    Delete(s, 1, Pos('|', s));
    cnaeClasse := Copy(s, 1, Pos('|', s)-1); Delete(s, 1, Pos('|', s));
    cnaeAtiv   := Copy(s, 1, Pos('|', s)-1); Delete(s, 1, Pos('|', s));
    cnaeEquipe := Copy(s, 1, Pos('|', s)-1); Delete(s, 1, Pos('|', s));
    cnaeComp   := s;
  end;

begin
  JsonArray := '[]';
  cod5 := NormalizeCodigo5(CodigoRegulado);

  T := TTable.Create(nil);
  try
    T.DatabaseName := AliasOrPath;
    T.TableName := 'CAE.DB';
    T.IndexName := 'PorCodigo';

    T.Open;
    try
      // CAE.CODIGO é o campo indexado. Vamos usar SetRange no texto A(5)
      T.SetRange([cod5], [cod5]);

      first := True;
      JsonArray := '[';

      T.First;
      while not T.Eof do
      begin
        caeCod := Trim(T.FieldByName('CODIGO').AsString);
        sub    := Trim(T.FieldByName('SUBCLASSE').AsString);
        classe := Trim(T.FieldByName('CLASSE').AsString);
        tipo   := Trim(T.FieldByName('TIPO').AsString);

        packed := MapCnae.Values[sub];
        ParseCnaePacked(packed);

        if not first then JsonArray := JsonArray + ',';
        first := False;

        JsonArray := JsonArray +
          '{' +
            '"cae_codigo":' + JStr(caeCod) + ',' +
            '"subclasse":' + JStr(sub) + ',' +
            '"classe":' + JStr(classe) + ',' +
            '"tipo":' + JStr(tipo) + ',' +
            '"atividade":' + IfThenW(cnaeAtiv<>'', JStr(cnaeAtiv), JNull) + ',' +
            '"equipe":' + IfThenW(cnaeEquipe<>'', JStr(cnaeEquipe), JNull) + ',' +
            '"complexidade":' + IfThenW(cnaeComp<>'', JStr(cnaeComp), JNull) +
          '}';

        T.Next;
      end;

      JsonArray := JsonArray + ']';
      if first then JsonArray := '[]'; // năo tinha nenhuma

    finally
      T.Close;
    end;
  finally
    T.Free;
  end;
end;

// -------- export: histórico 1:1 por NDOC --------
procedure ExportHistoricoPorNdoc(const AliasOrPath, BaseDir: string);
var
  T: TTable;
  ndoc: Integer;
  decr: string;
  bucket, outFile: string;
  W: WideString;
begin
  T := TTable.Create(nil);
  try
    T.DatabaseName := AliasOrPath;
    T.TableName := 'HISTORICO.DB';
    T.IndexName := 'PorNdoc'; // ajuste se o índice tiver outro nome; vocę disse que existe por chave
    // se o nome for "PorCodigo" năo serve aqui; precisa ser índice em NDOC.
    // se năo tiver índice, deixe vazio.

    T.Open;
    try
      T.First;
      while not T.Eof do
      begin
        ndoc := T.FieldByName('NDOC').AsInteger;
        decr := T.FieldByName('DECR').AsString;

        bucket := HisBucket(ndoc);
        outFile := BaseDir + 'his\' + bucket + '\' + IntToStr(ndoc) + '.json';

        W := '{' +
              '"ndoc":' + IntToStr(ndoc) + ',' +
              '"decr":' + JStr(decr) +
            '}';

        SaveUtf8ToFile(outFile, W);

        T.Next;
      end;
    finally
      T.Close;
    end;
  finally
    T.Free;
  end;
end;

// -------- export: índice de regulados + arquivo por regulado --------
procedure ExportReguladosPorArquivo(const AliasOrPath, BaseDir: string);
var
  Contrib: TTable;
  MapBairro: TStringList;
  MapCnae: TStringList;

  indexW: WideString;
  firstIndex: Boolean;

  codigo: Integer;
  prefix: string;
  outFile: string;

  // campos p/ busca
  razao, fantasia, cnpj, cpf, logradouro, complement, cep: string;
  cdbai: Integer;
  bairroNome: string;

  atividadesJson: WideString;
  inspecoesJson: WideString;
  alvaraUlt: WideString;

  inativo: Boolean;

  W: WideString;
begin
  MapBairro := TStringList.Create;
  MapCnae := TStringList.Create;
  Contrib := TTable.Create(nil);
  try
    LoadBairros(AliasOrPath, MapBairro);
    LoadCNAE(AliasOrPath, MapCnae);

    // índice de busca (leve)
    indexW := '{' +
                '"meta":{"origem":"CVS","gerado_em":' + JStr(NowISO_Brasilia) + '},' +
                '"dados":[';
    firstIndex := True;

    Contrib.DatabaseName := AliasOrPath;
    Contrib.TableName := 'CONTRIB.DB';
    Contrib.IndexName := 'PorCodigo';

    Contrib.Open;
    try
      Contrib.First;
      while not Contrib.Eof do
      begin
        // filtro: inatividade = true => năo exporta
        inativo := (not Contrib.FieldByName('INATIVIDADE').IsNull) and Contrib.FieldByName('INATIVIDADE').AsBoolean;
        if inativo then
        begin
          Contrib.Next;
          Continue;
        end;

        codigo := Contrib.FieldByName('CODIGO').AsInteger;
        prefix := RegPrefix(codigo);

        razao := Trim(Contrib.FieldByName('RAZAO').AsString);
        fantasia := Trim(Contrib.FieldByName('FANTASIA').AsString);
        cnpj := Trim(Contrib.FieldByName('CGC').AsString);
        cpf  := Trim(Contrib.FieldByName('CPF').AsString);
        logradouro := Trim(Contrib.FieldByName('LOGRADOURO').AsString);
        complement := Trim(Contrib.FieldByName('COMPLEMENT').AsString);
        cep := Trim(Contrib.FieldByName('CEP').AsString);

        if Contrib.FieldByName('CDBAI').IsNull then cdbai := 0 else cdbai := Contrib.FieldByName('CDBAI').AsInteger;
        bairroNome := MapBairro.Values[IntToStr(cdbai)];

        // monta dados enriquecidos sob demanda
        GetAtividadesJson(AliasOrPath, codigo, MapCnae, atividadesJson);
        GetInspecoesJson(AliasOrPath, codigo, inspecoesJson);
        alvaraUlt := UltimoAlvaraValidoJson(AliasOrPath, codigo);

        // escreve arquivo do regulado
        outFile := BaseDir + 'reg\' + prefix + '\' + IntToStr(codigo) + '.json';

        W :=
          '{' +
            '"codigo":' + IntToStr(codigo) + ',' +
            '"razao":' + JStr(razao) + ',' +
            '"fantasia":' + JStr(fantasia) + ',' +
            '"cnpj":' + IfThenW(cnpj<>'', JStr(cnpj), JNull) + ',' +
            '"cpf":' + IfThenW(cpf<>'', JStr(cpf), JNull) + ',' +
            '"endereco":{' +
              '"logradouro":' + JStr(logradouro) + ',' +
              '"complemento":' + IfThenW(complement<>'', JStr(complement), JNull) + ',' +
              '"cep":' + IfThenW(cep<>'', JStr(cep), JNull) +
            '},' +
            '"bairro":{' +
              '"codigo":' + IntToStr(cdbai) + ',' +
              '"nome":' + IfThenW(bairroNome<>'', JStr(bairroNome), JNull) +
            '},' +
            '"atividades":' + atividadesJson + ',' +
            '"alvara_ultimo":' + alvaraUlt + ',' +
            '"inspecoes":' + inspecoesJson +
          '}';

        SaveUtf8ToFile(outFile, W);

        // adiciona no índice (leve!)
        if not firstIndex then indexW := indexW + ',';
        firstIndex := False;

        // Mantém o índice enxuto (sem inspeçőes/atividades/alvará)
        indexW := indexW +
          '{' +
            '"codigo":' + IntToStr(codigo) + ',' +
            '"razao":' + JStr(razao) + ',' +
            '"fantasia":' + JStr(fantasia) + ',' +
            '"cnpj":' + IfThenW(cnpj<>'', JStr(cnpj), JNull) + ',' +
            '"cpf":' + IfThenW(cpf<>'', JStr(cpf), JNull) + ',' +
            '"logradouro":' + JStr(logradouro) + ',' +
            '"bairro_codigo":' + IntToStr(cdbai) +
          '}';

        Contrib.Next;
      end;
    finally
      Contrib.Close;
    end;

    indexW := indexW + ']}';
    SaveUtf8ToFile(BaseDir + 'index_regulados.json', indexW);

  finally
    Contrib.Free;
    MapCnae.Free;
    MapBairro.Free;
  end;
end;

// -------- funçăo principal para vocę chamar no botăo --------
function ExportarJsonCVS_Shared(const AliasOrPath, OutBaseDir: string; out Erro: string): Boolean;
var
  BaseDir: string;
begin
  Result := False;
  Erro := '';
  try
    BaseDir := EnsureSlash(OutBaseDir);
    // gera regulados ativos (índice + arquivos)
    ExportReguladosPorArquivo(AliasOrPath, BaseDir);
    // gera 1 arquivo por NDOC (histórico 1:1)
    ExportHistoricoPorNdoc(AliasOrPath, BaseDir);
    Result := True;
  except
    on E: Exception do
    begin
      Erro := E.ClassName + ': ' + E.Message;
      Result := False;
    end;
  end;
end;

end.

