cbfiscal.Text:=frmlogin.c_user;
if (frmlogin.c_grp = 'ADM') or (frmlogin.c_grp = 'FIS') then
begin
    cbfiscal.enabled:=true;
    cbfiscal.setfocus;
end
else cbfiscal.enabled:=false;
if (frmlogin.c_grp = 'ADM') or (frmlogin.c_grp = 'FIS') then BtOk.Enabled:=true else
  begin
      BtOk.Enabled:= false;
      cbfiscal.Text:= '';
  end;
end;

