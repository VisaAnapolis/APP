unit ParamSequencia;

interface

uses
  Windows, Messages, SysUtils, Classes, Graphics, Controls, Forms, Dialogs,
  DB, DBTables, StdCtrls, ExtCtrls, DBCtrls, Mask;

type
  TfrmParamSequencia = class(TForm)
    PanelTop: TPanel;
    BtnAlterar: TButton;
    BtnSalvar: TButton;
    BtnCancelar: TButton;
    BtnFechar: TButton;
    PanelEdicao: TPanel;
    Ds: TDataSource;
    Tb: TTable;
    LblNumero: TLabel;
    EdNumero: TDBEdit;
    LblDoc: TLabel;
    EdDoc: TDBEdit;
    LblDen: TLabel;
    EdDen: TDBEdit;
    LblOficio: TLabel;
    EdOficio: TDBEdit;
    LblPt: TLabel;
    EdPt: TDBEdit;
    LblProtocolo: TLabel;
    EdProtocolo: TDBEdit;
    LblAlvara: TLabel;
    EdAlvara: TDBEdit;
    LblVeiculo: TLabel;
    EdVeiculo: TDBEdit;
    BevelNum: TBevel;
    LblOrgao: TLabel;
    EdOrgao: TDBEdit;
    LblAutoridade1: TLabel;
    EdAutoridade1: TDBEdit;
    LblAutoridade2: TLabel;
    EdAutoridade2: TDBEdit;
    BevelSys: TBevel;
    LblMaster: TLabel;
    LblVersao: TLabel;
    EdVersao: TDBEdit;
    LblDtVersao: TLabel;
    EdDtVersao: TDBEdit;
    LblDisponibilidade: TLabel;
    CbDisponibilidade: TDBCheckBox;
    TbNumero: TIntegerField;
    TbDoc: TIntegerField;
    TbDen: TIntegerField;
    TbOficio: TIntegerField;
    TbPt: TIntegerField;
    TbProtocolo: TIntegerField;
    TbAlvara: TIntegerField;
    TbVeiculo: TIntegerField;
    TbAutoridade1: TStringField;
    TbAutoridade2: TStringField;
    TbOrgao: TStringField;
    TbVersao: TStringField;
    TbDtVersao: TStringField;
    TbDisponibilidade: TBooleanField;
    procedure FormActivate(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure BtnAlterarClick(Sender: TObject);
    procedure BtnSalvarClick(Sender: TObject);
    procedure BtnCancelarClick(Sender: TObject);
    procedure BtnFecharClick(Sender: TObject);
    procedure DsStateChange(Sender: TObject);
    procedure EdEnterAsTab(Sender: TObject; var Key: Char);
  private
    procedure AtualizaBotoes;
    procedure ApplyFieldRules;
    procedure EnterEditMode;
    procedure ExitEditMode;
  public
  end;

var
  frmParamSequencia: TfrmParamSequencia;

implementation

uses login;

{$R *.dfm}

procedure TfrmParamSequencia.EdEnterAsTab(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
  begin
    Key := #0;
    Perform(WM_NEXTDLGCTL, 0, 0);
  end;
end;

procedure TfrmParamSequencia.ApplyFieldRules;
var
  EhMaster: Boolean;
begin
  EhMaster := (frmlogin.c_user = 'CLﾁ拔DIO NASCIMENTO SILVA');

  Ds.AutoEdit := False;

  // Campos restritos ao master
  if not EhMaster then
  begin
    TbDisponibilidade.ReadOnly := True;
    TbVersao.ReadOnly          := True;
    TbDtVersao.ReadOnly        := True;
  end
  else
  begin
    TbDisponibilidade.ReadOnly := False;
    TbVersao.ReadOnly          := False;
    TbDtVersao.ReadOnly        := False;
  end;
end;

procedure TfrmParamSequencia.EnterEditMode;
begin
  PanelEdicao.Enabled := True;
  if EdNumero.CanFocus then EdNumero.SetFocus;
end;

procedure TfrmParamSequencia.ExitEditMode;
begin
  PanelEdicao.Enabled := False;
end;

procedure TfrmParamSequencia.FormActivate(Sender: TObject);
begin
  Session.AddPassword('paradiso');

  if not Tb.Active then
    Tb.Open;

  ApplyFieldRules;
  ExitEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamSequencia.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  if Tb.Active and (Tb.State in [dsEdit, dsInsert]) then
    Tb.Cancel;
  Action := caHide;
end;

procedure TfrmParamSequencia.BtnAlterarClick(Sender: TObject);
begin
  if Tb.IsEmpty then Exit;
  Tb.Edit;
  EnterEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamSequencia.BtnSalvarClick(Sender: TObject);
begin
  if Tb.State in [dsEdit, dsInsert] then
    Tb.Post;
  ExitEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamSequencia.BtnCancelarClick(Sender: TObject);
begin
  if Tb.State in [dsEdit, dsInsert] then
    Tb.Cancel;
  ExitEditMode;
  AtualizaBotoes;
end;

procedure TfrmParamSequencia.BtnFecharClick(Sender: TObject);
begin
  if Tb.Active and (Tb.State in [dsEdit, dsInsert]) then
    Tb.Cancel;
  Close;
end;

procedure TfrmParamSequencia.DsStateChange(Sender: TObject);
begin
  AtualizaBotoes;
end;

procedure TfrmParamSequencia.AtualizaBotoes;
var
  EmEdicao: Boolean;
begin
  if not Tb.Active then
  begin
    BtnAlterar.Enabled  := False;
    BtnSalvar.Enabled   := False;
    BtnCancelar.Enabled := False;
    Exit;
  end;

  EmEdicao := (Tb.State in [dsEdit, dsInsert]);

  BtnAlterar.Enabled  := (not EmEdicao) and (not Tb.IsEmpty);
  BtnSalvar.Enabled   := EmEdicao;
  BtnCancelar.Enabled := EmEdicao;
  BtnFechar.Enabled   := True;
end;

end.
